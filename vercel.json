{
  "version": 2,
  "builds": [
    { "src": "api/db.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/db", "dest": "/api/db.js" },
    { "src": "/verus-cs-final.html", "dest": "/verus-cs-final.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
